        "fontStyle": "",
      },
    },
    {
      "scope": "log.error",
      "settings": {
        "foreground": "$fg.红$",
        "fontStyle": "",
      },
    },
    {
      "scope": [
        "log.warning",
      ],
      "settings": {
        "foreground": "$fg.黄$",
        "fontStyle": "",
      },
    },
    {
      "scope": [
        "log.info",
      ],
      "settings": {
        "foreground": "$fg.绿$",
        "fontStyle": "",
      },
    },
    {
      "scope": [
        "log.debug",
      ],
      "settings": {
        "foreground": "$fg.青$",
        "fontStyle": "",
      },
