      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold",
      }
    },
    {
      "scope": "markup.heading",
      "settings": {
        "fontStyle": "bold",
      }
    },
