    "symbolIcon.moduleForeground": "$fg.标识符$",
    "symbolIcon.namespaceForeground": "$fg.标识符$",
    "symbolIcon.nullForeground": "$fg.默认$",
    "symbolIcon.numberForeground": "$fg.默认$",
    "symbolIcon.objectForeground": "$fg.默认$",
