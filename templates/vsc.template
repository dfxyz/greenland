      ],
      "settings": {
        "foreground": "$fg.链接$",
      },
    },
    {
      "scope": [
        "heading markup.underline.link",
      ],
      "settings": {
        "foreground": "$fg.链接$",
        "fontStyle": "bold",
      },
    },
    {
      "scope": "invalid",
      "settings": {
        "foreground": "$fg.红$",
      },
    },
    {
      "scope": "emphasis",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": "strong",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
