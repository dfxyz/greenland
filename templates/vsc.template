  "tokenColors": [
    {
      "scope": [
        "constant.language.import-export-all.ts",
        "keyword.operator",
        "keyword.other.unit",
        "meta.embedded",
        "meta.template.expression",
        "storage.modifier.pointer",
        "string.unquoted",
        "punctuation",
        "punctuation.definition.entity.css",
        "punctuation.definition.entity.begin.bracket.square.css",
        "punctuation.definition.entity.end.bracket.square.css",
        "punctuation.definition.tag",
      ],
      "settings": {
        "foreground": "$fg.默认$",
      },
    },
    {
      "scope": [
        "entity.name.function",
        "entity.name.variable",
        "string.unquoted.proto.package",
        "support.constant.color.w3c-standard-color-name.css",
        "support.function",
        "support.variable",
        "variable",
      ],
      "settings": {
        "foreground": "$fg.标识符$",
      },
    },
    {
      "scope": [
        "keyword",
        "keyword.operator.alignas",
        "keyword.operator.alignof",
        "keyword.operator.cast",
        "keyword.operator.expression",
        "keyword.operator.instanceof",
        "keyword.operator.logical.python",
        "keyword.operator.new",
        "keyword.operator.noexcept",
        "keyword.operator.sizeof",
        "keyword.operator.typeid",
        "keyword.operator.wordlike",
        "punctuation.definition.keyword.css",
        "storage",
        "variable.language.self",
        "variable.language.special.self",
        "variable.language.this",
        "variable.language.wildcard.java",
      ],
      "settings": {
        "foreground": "$fg.关键字$",
      },
    },
    {
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.name.type.instance.jsdoc",
        "storage.type.built-in",
        "support.type",
        "support.class",
      ],
      "settings": {
        "foreground": "$fg.类型$",
      },
    },
    {
      "scope": [
        "entity.name.tag.yaml",
        "entity.name.tag.yaml punctuation.definition.string",
        "entity.other.attribute-name",
        "support.type.property-name",
        "support.type.property-name punctuation.support.type.property-name",
        "support.type.vendored.property-name",
        "support.variable.property",
        "variable.object.property",
      ],
      "settings": {
        "foreground": "$fg.属性$",
