    "gitDecoration.renamedResourceForeground": "$fg.青$",
    "gitDecoration.modifiedResourceForeground": "$fg.蓝$",
    "gitDecoration.stageModifiedResourceForeground": "$fg.蓝$",
    "gitDecoration.deletedResourceForeground": "$fg.红$",
